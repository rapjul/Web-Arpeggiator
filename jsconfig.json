{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ]
  },
  "include": [
    "js/**/*.js",
    "types.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "sw.js"
  ]
}
